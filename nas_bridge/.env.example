# --- core ---
BRIDGE_ENV=development
BRIDGE_LOG_LEVEL=INFO
BRIDGE_HOST=0.0.0.0
BRIDGE_PORT=8080
BRIDGE_DATABASE_URL=sqlite:///./data/bridge.db
BRIDGE_SHARED_AUTH_TOKEN=replace-me
BRIDGE_WORKER_STALE_AFTER_SECONDS=90

# --- discord gateway ---
# Set DISCORD_DISABLE=true to run the bridge as HTTP-only (no Discord).
BRIDGE_DISABLE_DISCORD=false
DISCORD_BOT_TOKEN=
DISCORD_APPLICATION_ID=
DISCORD_SYNC_GUILD_IDS=[]

# --- v1 deprecation banner (F8) ---
# Logs a one-time WARNING at startup pointing at /v2 routes.
# Set false to silence once you've migrated clients.
BRIDGE_CHAT_V1_DEPRECATION_WARNING=true

# --- agents are external ---
# The bridge no longer spawns agents in-process. Run claude_executor on
# the worker PC(s) with CLAUDE_BRIDGE_ACTOR_HANDLE set; each instance
# subscribes to /v2/inbox/stream for its handle and posts speech.claim
# back via /v2/operations/{id}/events. Multi-agent = multiple executors.
# See pc_launcher/connectors/claude_executor/runner.py.

# --- digest behavior (B) ---
# Periodic rollup of every space's closed ops, posted as a system
# speech in that space's general conversation. 0 disables the cron.
# Production typical: 86400 (daily). Dev/demo: 3600 (hourly).
BRIDGE_DIGEST_INTERVAL_SECONDS=0

# --- load test opt-ins (β1, H4) ---
# These guard slow / costly tests. Leave unset in production.
# BRIDGE_RUN_LOAD_TESTS=1
# BRIDGE_ANTHROPIC_API_KEY=...   # also enables live LLM tests
