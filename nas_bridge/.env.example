# --- core ---
BRIDGE_ENV=development
BRIDGE_LOG_LEVEL=INFO
BRIDGE_HOST=0.0.0.0
BRIDGE_PORT=8080
BRIDGE_DATABASE_URL=sqlite:///./data/bridge.db
BRIDGE_SHARED_AUTH_TOKEN=replace-me
BRIDGE_WORKER_STALE_AFTER_SECONDS=90

# --- discord gateway ---
# Set DISCORD_DISABLE=true to run the bridge as HTTP-only (no Discord).
BRIDGE_DISABLE_DISCORD=false
DISCORD_BOT_TOKEN=
DISCORD_APPLICATION_ID=
DISCORD_SYNC_GUILD_IDS=[]

# --- v1 deprecation banner (F8) ---
# Logs a one-time WARNING at startup pointing at /v2 routes.
# Set false to silence once you've migrated clients.
BRIDGE_CHAT_V1_DEPRECATION_WARNING=true

# --- agent behavior (A) ---
# When BRIDGE_AGENT_ENABLED is true, the bridge spawns an in-process
# agent runner subscribed to the v2 inbox broker. It auto-responds to
# events addressed to its handle.
BRIDGE_AGENT_ENABLED=false
BRIDGE_AGENT_HANDLE=@bridge-agent
# Brain selection:
#   pc-claude  (DEFAULT) -- dispatch the prompt to a PC running
#                           claude_executor; uses the PC's logged-in
#                           Claude session (no API key on the bridge).
#                           Requires BRIDGE_AGENT_PC_MACHINE_ID + _CWD.
#   echo                 -- deterministic stub for testing wiring.
#   claude               -- direct anthropic SDK (test/dev only;
#                           anthropic NOT bundled in default image).
BRIDGE_AGENT_BRAIN=pc-claude

# pc-claude requires these:
BRIDGE_AGENT_PC_MACHINE_ID=         # e.g. "pc-A" -- machine_id of the
                                    # registered claude_executor agent
BRIDGE_AGENT_PC_CWD=                # working directory to start the
                                    # claude run in (absolute path on PC)
BRIDGE_AGENT_PC_PERMISSION_MODE=acceptEdits   # acceptEdits | plan | etc.
# Optional model override for pc-claude (defaults to PC's claude default)
# BRIDGE_AGENT_MODEL=

# claude (api-key) brain only -- NOT recommended for production
# BRIDGE_ANTHROPIC_API_KEY=
# BRIDGE_AGENT_SYSTEM_PROMPT="..."

# --- additional agent slots (multi-agent) ---
# Slots 2..8 are optional. Each slot needs at minimum a HANDLE; pc-claude
# slots additionally need PC_MACHINE_ID + PC_CWD pointing at a separately
# running claude_executor instance (typically on a different PC, or on the
# same PC with a distinct CLAUDE_BRIDGE_MACHINE_ID).
# BRIDGE_AGENT_2_HANDLE=@bridge-reviewer
# BRIDGE_AGENT_2_BRAIN=pc-claude
# BRIDGE_AGENT_2_PC_MACHINE_ID=pc-B
# BRIDGE_AGENT_2_PC_CWD=/home/user/project
# BRIDGE_AGENT_2_PC_PERMISSION_MODE=acceptEdits
# BRIDGE_AGENT_2_MODEL=

# --- digest behavior (B) ---
# Periodic rollup of every space's closed ops, posted as a system
# speech in that space's general conversation. 0 disables the cron.
# Production typical: 86400 (daily). Dev/demo: 3600 (hourly).
BRIDGE_DIGEST_INTERVAL_SECONDS=0

# --- load test opt-ins (β1, H4) ---
# These guard slow / costly tests. Leave unset in production.
# BRIDGE_RUN_LOAD_TESTS=1
# BRIDGE_ANTHROPIC_API_KEY=...   # also enables live LLM tests
